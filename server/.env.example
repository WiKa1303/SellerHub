# PostgreSQL-Verbindung (Railway/Render/Neon stellen die URL bereit)
DATABASE_URL=postgres://user:pass@host:5432/sellerhub_radar

# API-Port
PORT=8787

# Crawl-Zeitplan (Cron-Syntax) – Standard: 6:00 + 15:00 Uhr
# ⚠️ Läuft in der SERVER-Zeitzone! Container (Railway/Docker) sind standardmäßig UTC —
#    deshalb zusätzlich TZ setzen, sonst crawlt "15:00" um 17:00 deutscher Zeit.
TZ=Europe/Berlin
CRAWL_CRON=0 6,15 * * *

# Beim Prozess-Start sofort crawlen (true/false)
CRAWL_ON_BOOT=true

# Nur Items ab diesem Relevanz-Score speichern (0–100)
SCORE_THRESHOLD=25

# Maximales Artikel-Alter in Tagen
MAX_AGE_DAYS=30

# Schlüssel für POST /api/admin/crawl
ADMIN_KEY=bitte-aendern

# ═══ KI-Analyse (Phase 3) — optional; ohne Key läuft Keyword-Scoring weiter ═══
# ANTHROPIC_API_KEY=sk-ant-...
# Modell (Standard: claude-opus-4-8; günstigere Alternativen: claude-sonnet-4-6, claude-haiku-4-5)
AI_MODEL=claude-opus-4-8
# Kostenbremsen: max. Analysen pro Lauf / max. Versuche pro Item / Parallelität
AI_MAX_PER_RUN=60
AI_MAX_ATTEMPTS=3
AI_CONCURRENCY=2

# Log-Format: leer = menschenlesbar (Dev), json = JSON-Zeilen (Produktion/Aggregatoren)
LOG_FORMAT=

# ═══ Push-Zustellung (Phase 5) — beide optional; ohne beide bleibt Push inaktiv (Skip mit Log) ═══
# Generischer JSON-Webhook: POST {title, severity, url, published_at, source}
# PUSH_WEBHOOK_URL=https://example.com/mein-hook
# ntfy.sh-Topic (kontofrei): Topic-Namen wählen und in der ntfy-App abonnieren — fertig
# PUSH_NTFY_TOPIC=sellerhub-alerts-zufallssuffix
