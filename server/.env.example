# PostgreSQL-Verbindung (Railway/Render/Neon stellen die URL bereit)
DATABASE_URL=postgres://user:pass@host:5432/sellerhub_radar

# API-Port
PORT=8787

# Crawl-Zeitplan (Cron-Syntax) – Standard: 6:00 + 15:00 Uhr
CRAWL_CRON=0 6,15 * * *

# Beim Prozess-Start sofort crawlen (true/false)
CRAWL_ON_BOOT=true

# Nur Items ab diesem Relevanz-Score speichern (0–100)
SCORE_THRESHOLD=25

# Maximales Artikel-Alter in Tagen
MAX_AGE_DAYS=30

# Schlüssel für POST /api/admin/crawl
ADMIN_KEY=bitte-aendern

# ═══ KI-Analyse (Phase 3) — optional; ohne Key läuft Keyword-Scoring weiter ═══
# ANTHROPIC_API_KEY=sk-ant-...
# Modell (Standard: claude-opus-4-8; günstigere Alternativen: claude-sonnet-4-6, claude-haiku-4-5)
AI_MODEL=claude-opus-4-8
# Kostenbremsen: max. Analysen pro Lauf / max. Versuche pro Item / Parallelität
AI_MAX_PER_RUN=60
AI_MAX_ATTEMPTS=3
AI_CONCURRENCY=2
